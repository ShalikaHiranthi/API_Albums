
@hostname = 127.0.0.1 
@port = {{$dotenv PORT}} 
@host = {{hostname}}:{{port}}
@VehicleID = {{createVehicle.response.body.data._id}}

### Get all
GET http://{{host}}/api/vehicles/

### Create
# A named request can be used to store fields that are returned from a response
# so theree's no need to copy-paste the same values in multiple requests
# Using the same name for multiple requests will overwrite the previous value
# @name createVehicle
POST http://{{host}}/api/vehicles/
Content-Type: application/json

{
    "type":"EV",
    "make":"Hyundai",
    "model":"Kona"
}

